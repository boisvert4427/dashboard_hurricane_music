{% extends 'base.html.twig' %}

{% block title %}Dashboard Hurricane Music{% endblock %}

{% block body %}
    <main class="app-shell">
        <header class="topbar">
            <div class="brand">
                <div class="brand-mark">HM</div>
                <div>
                    <div class="brand-name">Hurricane Music</div>
                    <div class="brand-subtitle">Dashboard de pilotage interne</div>
                </div>
            </div>
            <div class="status-pills">
                <span class="pill pill-accent">{{ period_label }}</span>
                <span class="pill">{{ previous_period_label }}</span>
            </div>
        </header>

        <section class="hero">
            <div class="hero-copy">
                <div class="eyebrow">Vue d'ensemble</div>
                <h1>Lecture mensuelle du business, puis détail par canal.</h1>
                <p>
                    La première version se concentre sur une seule source de vérité: les lignes de facture
                    <code>K_Li_FAC</code>, pour suivre le mois en cours et comparer avec N-1.
                </p>
            </div>
            <div class="hero-card">
                <div class="hero-card-label">Statut</div>
                <div class="hero-card-value">Base en cours</div>
                <p>La structure Symfony est prête pour brancher l'ETL et la table de reporting.</p>
            </div>
        </section>

        <section class="section">
            <div class="section-head">
                <h2>Global depuis le 1er</h2>
                <p>Les quatre chiffres que tu veux voir en premier.</p>
            </div>

            <div class="kpi-grid">
                {% for kpi in kpis %}
                    <article class="kpi-card">
                        <div class="kpi-label">{{ kpi.label }}</div>
                        <div class="kpi-value">{{ kpi.value }}</div>
                        <div class="kpi-hint">{{ kpi.hint }}</div>
                    </article>
                {% endfor %}
            </div>
        </section>

        <section class="section">
            <div class="section-head">
                <h2>Canaux de vente</h2>
                <p>Répartition à construire à partir des indices présents dans <code>K_Li_FAC</code>.</p>
            </div>

            <div class="channel-grid">
                {% for channel in channels %}
                    <article class="channel-card">
                        <div class="channel-label">{{ channel.label }}</div>
                        <div class="channel-value">{{ channel.value }}</div>
                        <div class="channel-hint">{{ channel.hint }}</div>
                    </article>
                {% endfor %}
            </div>
        </section>
    </main>
{% endblock %}
